{
  "$schema": "https://turborepo.com/schema.json",
  "globalDependencies": [
    ".env",
    ".env.example"
  ],
  "globalEnv": [
    "NODE_ENV",
    "NUXT_PUBLIC_SUPABASE_URL",
    "NUXT_PUBLIC_SUPABASE_ANON_KEY",
    "SUPABASE_SERVICE_ROLE_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": [
        "^typecheck"
      ],
      "outputs": [
        ".nuxt/**",
        ".vercel/output/**",
        ".output/**",
        "dist/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": [
        "^typecheck"
      ],
      "outputs": []
    },
    "clean": {
      "cache": false
    }
  }
}
